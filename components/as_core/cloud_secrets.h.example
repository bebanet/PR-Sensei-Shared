/* cloud_secrets.h.example — template for the gitignored cloud_secrets.h.
 *
 * Copy to cloud_secrets.h and fill in. These seed NVS ("pr_cloud") on first
 * boot if NVS is empty; runtime/UI changes via pr_cloud_save_config() override.
 * Leaving PR_CLOUD_ENDPOINT empty keeps the cloud uplink idle (device works
 * normally). Do NOT commit cloud_secrets.h — it is in .gitignore.
 */
#pragma once

/* AWS IoT Core ATS data endpoint, host only (no scheme, no :8883).
   Console: AWS IoT → Settings → Device data endpoint, region us-east-1.
   e.g. "a1b2c3d4e5f6g7-ats.iot.us-east-1.amazonaws.com" */
#define PR_CLOUD_ENDPOINT  ""

/* Telemetry topic {account} segment. The IoT policy wildcards it, so a dev
   placeholder is fine for this step. */
#define PR_CLOUD_ACCOUNT   "dev"

/* MQTT clientId = AWS IoT thing name (the policy authorizes by it).
   Leave "" to derive "pr-<sta-mac>" at runtime (matches the contract pattern
   and the recommended thing name). Set this only if your thing has a fixed
   test name that differs from pr-<mac>. */
#define PR_CLOUD_CLIENTID  ""
